{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/", "destination": "/api/og?path=/", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(bot|crawler|spider|facebook|twitter|linkedin|slack|discord|whatsapp|telegram|pinterest).*" }] },
    { "source": "/(.*)", "destination": "/api/og?path=$1", "has": [{ "type": "header", "key": "user-agent", "value": "(?i).*(bot|crawler|spider|facebook|twitter|linkedin|slack|discord|whatsapp|telegram|pinterest).*" }] },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
