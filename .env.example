# SMTP Gmail (wajib untuk form kontak)
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# MongoDB Atlas (opsional, tanpa ini panel admin read-only)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/beresin?retryWrites=true&w=majority

# Admin Panel (wajib untuk akses admin)
ADMIN_PASSWORD=your-strong-admin-password
JWT_SECRET=your-random-jwt-secret-min-32-characters

# Cloudinary (opsional, tanpa ini gambar disimpan lokal/tmp)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
